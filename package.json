{
  "name": "patch-panel",
  "version": "0.1.0",
  "private": true,
  "description": "Patch Panel monorepo — Chrome extension + landing page.",
  "scripts": {
    "dev": "pnpm --filter extension dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "cf:deploy": "pnpm --filter landing cf:deploy",
    "cf:deploy:preview": "pnpm --filter landing cf:deploy:preview"
  },
  "packageManager": "pnpm@10.32.1"
}
